# Copy to `.env` (never commit) and fill in the values you want.
# All keys are optional — the app falls back to local-only mode if none are set.

# OpenAI Whisper API (cloud STT)
OPENAI_API_KEY=

# LLM cleanup providers (any one)
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLAMACPP_BASE_URL=http://localhost:8080

# Override sidecar data dir (defaults to OS-specific app-data path)
ULTIMATEASR_DATA_DIR=
